NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional; public /support page defaults to support@hearthustlefund.com if unset
NEXT_PUBLIC_SUPPORT_EMAIL=
# Twilio — campaign reminder SMS (see /api/cron/campaign-reminder-sms)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# A2P 10DLC: prefer Messaging Service SID (MG…) so sends use your registered campaign
TWILIO_MESSAGING_SERVICE_SID=
# Fallback if messaging service unset (raw long code — may fail 30034 without A2P)
TWILIO_FROM_NUMBER=
# Random string; Vercel Cron sends Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

SUPERADMIN_EMAIL=you@yourdomain.com
# Optional HMAC secret for coach “email + code” activation cookie. If unset, SUPABASE_SERVICE_ROLE_KEY is used (server-only).
COACH_ACTIVATION_SECRET=
